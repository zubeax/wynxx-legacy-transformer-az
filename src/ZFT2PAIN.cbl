                       Nm OF Cdtr                IS "Nm"
                       CdtrAcct                  IS "CdtrAcct"
                       CdtrAcctId OF CdtrAcct    IS "Id"
                       IBAN OF CdtrAcctId OF CdtrAcct
                                                 IS "IBAN"
                       RmtInf                    IS "RmtInf"
                       Ustrd                     IS "Ustrd"
               TYPE OF InstdAmtCcy               IS ATTRIBUTE
           END-XML

           IF XML-LEN > 0
           THEN
              PERFORM WRITE-CHUNKS
           END-IF
           .
           EXIT.

       WRITE-CHUNKS SECTION.
           MOVE XML-LEN TO REM
           PERFORM UNTIL REM <= 0
              COMPUTE OUT-LEN = FUNCTION MIN(REM, 4000)
              MOVE XML-OUT(PTR:OUT-LEN) TO OUT-REC
              WRITE OUT-REC
              ADD OUT-LEN TO PTR
              SUBTRACT OUT-LEN FROM REM
           END-PERFORM
