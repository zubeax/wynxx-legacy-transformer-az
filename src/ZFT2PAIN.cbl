                       NbOfTxs                   IS "NbOfTxs"
                       CtrlSum                   IS "CtrlSum"
                       InitgPty                  IS "InitgPty"
                       Nm OF InitgPty            IS "Nm"
                       PmtInf                    IS "PmtInf"
                       PmtInfId                  IS "PmtInfId"
                       PmtMtd                    IS "PmtMtd"
                       BtchBookg                 IS "BtchBookg"
                       NbOfTxs2                  IS "NbOfTxs"
                       CtrlSum2                  IS "CtrlSum"
                       PmtTpInf                  IS "PmtTpInf"
                       SvcLvl                    IS "SvcLvl"
                       SvcCode OF SvcLvl         IS "Cd"
                       ReqdExctnDt               IS "ReqdExctnDt"
                       Dbtr                      IS "Dbtr"
                       Nm OF Dbtr                IS "Nm"
                       DbtrAcct                  IS "DbtrAcct"
                       DbtrAcctId OF DbtrAcct    IS "Id"
                       IBAN OF DbtrAcctId OF DbtrAcct
                                                 IS "IBAN"
                       Ccy OF DbtrAcct           IS "Ccy"
                       DbtrAgt                   IS "DbtrAgt"
                       FinInstnId                IS "FinInstnId"
                       BIC                       IS "BIC"
                       ChrgBr                    IS "ChrgBr"
                       CdtTrfTxInf               IS "CdtTrfTxInf"
                       PmtId                     IS "PmtId"
                       InstrId                   IS "InstrId"
                       EndToEndId                IS "EndToEndId"
