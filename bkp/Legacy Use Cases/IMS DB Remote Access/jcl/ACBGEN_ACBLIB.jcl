
//ACBGEN  JOB (ACCT),'ACB BUILD',CLASS=A,MSGCLASS=X,NOTIFY=&SYSUID
//* Build/refresh ACBs in ACBLIB from PSBLIB (and DBDLIB if used)
//ACBMAINT EXEC PGM=DFS3UACB,REGION=0M,PARM='ACBGEN'
//STEPLIB  DD  DISP=SHR,DSN=IMS.SDFSRESL
//IMS      DD  DISP=SHR,DSN=IMS.PSBLIB
//         DD  DISP=SHR,DSN=IMS.DBDLIB
//ACBLIB   DD  DISP=SHR,DSN=IMS.ACBLIB
//SYSUDUMP DD  SYSOUT=*
//SYSPRINT DD  SYSOUT=*
//SYSIN    DD  *
  BUILD PSB=ECHOPSB
/*
