
//CATUPD  JOB (ACCT),'IMS CATALOG UPDATE',CLASS=A,MSGCLASS=X,NOTIFY=&SYSUID
//* Example wrapper for catalog-based ACB management
//STEP1    EXEC PGM=DFS3PU00,REGION=0M
//STEPLIB  DD  DISP=SHR,DSN=IMS.SDFSRESL
//CATALOG  DD  DISP=SHR,DSN=IMS.ACB.CATALOG
//PSBLIB   DD  DISP=SHR,DSN=IMS.PSBLIB
//DBDLIB   DD  DISP=SHR,DSN=IMS.DBDLIB
//SYSPRINT DD  SYSOUT=*
//SYSUDUMP DD  SYSOUT=*
//SYSIN    DD  *
  IMPORT PSB=(ECHOPSB)
  ACTIVATE CURRENT
/*
