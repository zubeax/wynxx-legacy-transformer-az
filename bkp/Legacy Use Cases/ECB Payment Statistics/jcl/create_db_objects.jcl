//PAYSTDDL JOB (ACCT),'CREATE DB',CLASS=A,MSGCLASS=X,MSGLEVEL=(1,1)
// SET HLQ=YOUR.HLQ
// SET SSID=DSN1
// SET DB2LOAD='DSN!!.SDSNLOAD'
// EXECUTE  EXEC PGM=IKJEFT01,REGION=0M
//STEPLIB  DD  DISP=SHR,DSN=&DB2LOAD
//SYSTSPRT DD  SYSOUT=*
//SYSPRINT DD  SYSOUT=*
//SYSTSIN  DD  *
 DSN SYSTEM(&SSID)
 RUN PROGRAM(DSNTEP2) PLAN(DSNTEP71)  -
  LIB('&DB2LOAD') PARMS('SQL')
 END
